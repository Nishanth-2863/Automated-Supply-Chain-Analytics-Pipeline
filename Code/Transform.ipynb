    "DATABASE_URL = f\"postgresql+psycopg2://{USER}:{PASSWORD}@{HOST}:{PORT}/{DATABASE}\"\n",
    "\n",
    "# Create engine\n",
    "engine = create_engine(DATABASE_URL)\n",
    "\n",
    "# Test query\n",
    "df = pd.read_sql(\"SELECT * FROM dim_customers LIMIT 5\", engine)\n",
    "\n",
